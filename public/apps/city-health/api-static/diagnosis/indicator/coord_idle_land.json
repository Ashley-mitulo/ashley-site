ention","statusText":"关注","trend":{"direction":"improving","text":"较2019年改善51.9%","delta":166,"rate":51.9},"series":[{"year":2019,"value":320,"score":66,"status":"warning"},{"year":2020,"value":360,"score":69,"status":"warning"},{"year":2021,"value":405,"score":72,"status":"warning"},{"year":2022,"value":438,"score":74,"status":"warning"},{"year":2023,"value":462,"score":78,"status":"attention"},{"year":2024,"value":486,"score":85,"status":"attention"}],"relationScore":1}],"relatedKnowledge":[{"id":"policy_urban_renewal","title":"城市更新与存量土地再开发要求","type":"policy","tags":["城市更新","闲置土地","建设用地","协调"],"content":"城市更新应坚持存量优先、内涵提升，推动低效用地再开发和闲置土地处置。建设用地扩张与闲置土地处置率偏低并存，往往说明空间增长方式仍偏外延，存量盘活机制有待完善。","score":14},{"id":"seed_urban_renewal_008","title":"城市更新与存量低效用地诊断知识","type":"policy_seed","tags":["城市更新","闲置土地","低效用地","存量再开发","协调"],"content":"城市更新强调从增量扩张转向存量提质，通过老旧小区改造、低效工业用地再开发、闲置土地处置、公共空间提升和基础设施补短板改善城市品质。若城乡建设用地规模偏高、闲置土地处置率偏低、工业用地占比下降过快，可能说明外延扩张与存量盘活不协调。治理建议包括建立低效用地清单、分类推进更新、完善利益平衡机制、保障产业空间和公共服务补短板。","sourceNote":"种子语料：基于城市更新政策和存量土地治理逻辑整理","uploadedAt":"2026-06-08T10:40:00+08:00","score":14},{"id":"seed_industrial_land_009","title":"工业用地和产业空间保障诊断知识","type":"indicator_seed","tags":["工业用地","产业空间","创新","制造业","用地保障"],"content":"工业用地占比反映产业空间保障能力。工业用地占比过快下降可能造成先进制造业和科创产业承载空间不足，影响产业链稳定和创新转化。诊断时应结合高新技术企业数量、科创空间面积、闲置土地处置率和低效工业用地再开发情况综合判断。治理建议包括划定工业用地保障线、推动低效工业用地再开发、提升产业空间复合利用效率和加强产业载体供给。","sourceNote":"种子语料：基于产业空间与工业用地保障逻辑整理","uploadedAt":"2026-06-08T10:40:00+08:00","score":3}],"generatedAt":"2026-07-17T07:29:25.455Z"}}