// ============================================================
// 🧠 港口智能算法优化中心 - v2.1 双算法对比 + 实时折线图
// ============================================================

let currentAlgoTab = 'compare';
let greedyStep = 0;
let astarStep = 0;
let simBoxes = 80;
let simStacks = 16;
let simBuffers = 4;
let greedyState = [];
let greedyTrucks = [];
let astarState = [];
let astarTrucks = [];
let simSequence = [];
let autoPlayTimer = null;
let chartHistory = []; // 记录每一步的翻箱数，用于折线图

function renderOptimization(container) {
    container.innerHTML = '' +
        '<div class="page-title">🧠 港口智能算法优化中心</div>' +
        '<div class="tab-container">' +
        '<div class="tab-item" onclick="switchAlgoTab(\'theory\')">📖 算法原理</div>' +
        '<div class="tab-item active" onclick="switchAlgoTab(\'compare\')">⚔️ 双算法对比</div>' +
        '<div class="tab-item" onclick="switchAlgoTab(\'routing\')">🚛 集卡路径优化</div>' +
        '</div>' +
        '<div id="algo-tab-content"></div>';
    setTimeout(function() { switchAlgoTab('compare'); }, 50);
}

function switchAlgoTab(tab) {
    currentAlgoTab = tab;
    var items = document.querySelectorAll('.tab-container .tab-item');
    var tabs = ['theory', 'compare', 'routing'];
    for (var i = 0; i < items.length; i++) {
        items[i].classList.remove('active');
        if (tabs[i] === tab) items[i].classList.add('active');
    }
    var content = document.getElementById('algo-tab-content');
    if (tab === 'theory') renderAlgoTheory(content);
    else if (tab === 'compare') renderCRPLaboratory(content);
    else if (tab === 'routing') renderRoutingAlgo(content);
}

// 初始化双场景
function initDualSimulator() {
    var initial = [];
    var boxesPlaced = 0;
    for (var s = 0; s < simStacks; s++) {
        initial[s] = [];
        var stackHeight = Math.floor(Math.random() * 7) + 3;
        for (var h = 0; h < stackHeight && boxesPlaced < simBoxes; h++) {
            boxesPlaced++;
            initial[s].push(boxesPlaced);
        }
    }
    
    simSequence = [];
    for (var b = 1; b <= simBoxes; b++) simSequence.push(b);
    for (var i = simSequence.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var t = simSequence[i];
        simSequence[i] = simSequence[j];
        simSequence[j] = t;
    }
    
    greedyState = JSON.parse(JSON.stringify(initial));
    astarState = JSON.parse(JSON.stringify(initial));
    
    greedyTrucks = [];
    astarTrucks = [];
    for (var t = 0; t < 6; t++) {
        var cap = Math.floor(simBoxes / 6) + 3;
        greedyTrucks[t] = { loaded: 0, capacity: cap };
        astarTrucks[t] = { loaded: 0, capacity: cap };
    }
    
    greedyStep = 0;
    astarStep = 0;
    chartHistory = [];
    if (autoPlayTimer) { clearInterval(autoPlayTimer); autoPlayTimer = null; }
    renderDualSimulator();
}

// 渲染堆场
function renderStacks(state) {
    var html = '<div style="display: flex; gap: 4px; justify-content: center; flex-wrap: wrap; padding: 10px;">';
    for (var s = 0; s < simStacks; s++) {
        var isBuffer = s >= simStacks - simBuffers;
        html += '<div style="display: flex; flex-direction: column; align-items: center; gap: 1px;">' +
            '<div style="color: ' + (isBuffer ? '#b388ff' : '#7a9aba') + '; font-size: 8px; margin-bottom: 2px;">' +
            (isBuffer ? 'B' : (s + 1)) + '</div>';
        
        var stack = state[s] || [];
        for (var h = stack.length - 1; h >= 0; h--) {
            html += '<div style="' +
                'width: 22px; height: 18px; background: #4a90d9; border-radius: 2px; ' +
                'display: flex; align-items: center; justify-content: center; color: #fff; ' +
                'font-weight: 700; font-size: 7px; transition: all 0.3s ease;"></div>';
        }
        for (var h = stack.length; h < 10; h++) {
            html += '<div style="width: 22px; height: 18px; border: 1px dashed rgba(122,154,186,0.1); border-radius: 2px;"></div>';
        }
        html += '</div>';
    }
    html += '</div>';
    return html;
}

// 贪心算法（传统作业）：✅ 已修复Bug！
function greedyNextStep() {
    if (greedyStep >= simBoxes) return;
    var targetBox = simSequence[greedyStep];
    var targetStack = -1, targetIndex = -1;
    
    for (var s = 0; s < simStacks; s++) {
        var idx = (greedyState[s] || []).indexOf(targetBox);
        if (idx >= 0) { targetStack = s; targetIndex = idx; break; }
    }
    
    if (targetStack < 0) return;
    
    if (targetIndex === greedyState[targetStack].length - 1) {
        for (var t = 0; t < 6; t++) {
            if (greedyTrucks[t].loaded < greedyTrucks[t].capacity) {
                greedyState[targetStack].pop();
                greedyTrucks[t].loaded++;
                greedyStep++;
                break;
            }
        }
    } else {
        var topBox = greedyState[targetStack][greedyState[targetStack].length - 1];
        greedyState[targetStack].pop();
        var bestStack = -1, bestHeight = 999;
        for (var s = 0; s < simStacks; s++) {
            if (s !== targetStack && (greedyState[s] || []).length < 10) {
                var height = greedyState[s].length;
                if (height < bestHeight) { bestHeight = height; bestStack = s; }
            }
        }
        if (bestStack >= 0) {
            greedyState[bestStack].push(topBox); // ✅ 修复：放的是顶上的箱子，不是目标箱
        }
    }
}

// A*智能算法
function astarNextStep() {
    if (astarStep >= simBoxes) return;
    var targetBox = simSequence[astarStep];
    var targetStack = -1, targetIndex = -1;
    
    for (var s = 0; s < simStacks; s++) {
        var idx = (astarState[s] || []).indexOf(targetBox);
        if (idx >= 0) { targetStack = s; targetIndex = idx; break; }
    }
    
    if (targetStack < 0) return;
    
    if (targetIndex === astarState[targetStack].length - 1) {
        for (var t = 0; t < 6; t++) {
            if (astarTrucks[t].loaded < astarTrucks[t].capacity) {
                astarState[targetStack].pop();
                astarTrucks[t].loaded++;
                astarStep++;
                break;
            }
        }
    } else {
        var topBox = astarState[targetStack][astarState[targetStack].length - 1];
        astarState[targetStack].pop();
        var bestStack = -1, minBadness = 9999;
        
        var boxPos = simSequence.indexOf(topBox);
        for (var s = 0; s < simStacks; s++) {
            if (s !== targetStack && (astarState[s] || []).length < 10) {
                var badness = astarState[s].length;
                for (var h = 0; h < astarState[s].length; h++) {
                    var otherPos = simSequence.indexOf(astarState[s][h]);
                    if (otherPos < boxPos) badness += 100;
                }
                if (s >= simStacks - simBuffers) badness -= 50;
                if (badness < minBadness) { minBadness = badness; bestStack = s; }
            }
        }
        if (bestStack >= 0) {
            astarState[bestStack].push(topBox);
        }
    }
}

// 执行一步对比
function dualNextStep() {
    for (var i = 0; i < 3; i++) greedyNextStep();
    for (var i = 0; i < 3; i++) astarNextStep();
    renderDualSimulator();
}

// 渲染折线图
function renderChart() {
    if (chartHistory.length < 2) return;
    
    var maxVal = Math.max(
        chartHistory.reduce((m, p) => Math.max(m, p.greedy), 0),
        chartHistory.reduce((m, p) => Math.max(m, p.astar), 0),
        50
    );
    
    var width = 800;
    var height = 220;
    var padding = 35;
    
    // 贪心曲线点
    var greedyPath = '';
    var astarPath = '';
    for (var i = 0; i < chartHistory.length; i++) {
        var x = padding + (i / (chartHistory.length - 1)) * (width - padding * 2);
        var gy = height - padding - (chartHistory[i].greedy / maxVal) * (height - padding * 2);
        var ay = height - padding - (chartHistory[i].astar / maxVal) * (height - padding * 2);
        greedyPath += (i === 0 ? 'M' : 'L') + x + ',' + gy + ' ';
        astarPath += (i === 0 ? 'M' : 'L') + x + ',' + ay + ' ';
    }
    
    var chartEl = document.getElementById('relocation-chart');
    if (chartEl) {
        chartEl.innerHTML = '<svg width="' + width + '" height="' + height + '" style="max-width:100%;display:block;margin:0 auto;">' +
            // 网格线
            '<line x1="' + padding + '" y1="' + padding + '" x2="' + padding + '" y2="' + (height - padding) + '" stroke="rgba(122,154,186,0.2)" stroke-width="1"/>' +
            '<line x1="' + padding + '" y1="' + (height - padding) + '" x2="' + (width - padding) + '" y2="' + (height - padding) + '" stroke="rgba(122,154,186,0.2)" stroke-width="1"/>' +
            // Y轴刻度
            '<text x="' + (padding - 5) + '" y="' + padding + '" fill="#7a9aba" font-size="10" text-anchor="end">' + maxVal + '</text>' +
            '<text x="' + (padding - 5) + '" y="' + (height - padding) + '" fill="#7a9aba" font-size="10" text-anchor="end">0</text>' +
            // 曲线
            '<path d="' + greedyPath + '" fill="none" stroke="#ff6b6b" stroke-width="2.5"/>' +
            '<path d="' + astarPath + '" fill="none" stroke="#00ff88" stroke-width="2.5"/>' +
            // 图例
            '<rect x="' + (width - padding - 120) + '" y="' + (padding + 5) + '" width="12" height="12" fill="#ff6b6b" rx="2"/>' +
            '<text x="' + (width - padding - 100) + '" y="' + (padding + 15) + '" fill="#7a9aba" font-size="11">传统贪心</text>' +
            '<rect x="' + (width - padding - 120) + '" y="' + (padding + 25) + '" width="12" height="12" fill="#00ff88" rx="2"/>' +
            '<text x="' + (width - padding - 100) + '" y="' + (padding + 35) + '" fill="#7a9aba" font-size="11">A*智能</text>' +
            '<text x="' + (width / 2) + '" y="18" fill="#a0c4e8" font-size="12" text-anchor="middle">📈 翻箱数累计对比曲线</text>' +
        '</svg>';
    }
}

// 渲染双对比
function renderDualSimulator() {
    var greedyYard = document.getElementById('greedy-yard');
    var astarYard = document.getElementById('astar-yard');
    if (greedyYard) greedyYard.innerHTML = renderStacks(greedyState);
    if (astarYard) astarYard.innerHTML = renderStacks(astarState);
    
    var greedyTotal = 0;
    for (var s = 0; s < simStacks; s++) greedyTotal += (greedyState[s] || []).length;
    var greedyReloc = Math.max(0, greedyTotal + greedyStep - simBoxes);
    
    var astarTotal = 0;
    for (var s = 0; s < simStacks; s++) astarTotal += (astarState[s] || []).length;
    var astarReloc = Math.max(0, astarTotal + astarStep - simBoxes);
    
    var saving = Math.max(0, greedyReloc - astarReloc);
    var percent = greedyReloc > 0 ? Math.round(saving / greedyReloc * 100) : 0;
    
    var el = document.getElementById('greedy-progress');
    if (el) el.textContent = greedyStep + '/' + simBoxes;
    el = document.getElementById('greedy-reloc');
    if (el) el = greedyReloc + '次';
    el = document.getElementById('astar-progress');
    if (el) el.textContent = astarStep + '/' + simBoxes;
    el = document.getElementById('astar-reloc');
    if (el) el.textContent = astarReloc + '次';
    el = document.getElementById('saving-count');
    if (el) el.textContent = saving + '次 (' + percent + '%)';
    
    // 记录历史数据，用于折线图
    if (greedyStep > 0 || astarStep > 0) {
        chartHistory.push({ greedy: greedyReloc, astar: astarReloc });
        renderChart();
    }
    
    if (astarStep >= simBoxes && greedyStep >= simBoxes && autoPlayTimer) {
        clearInterval(autoPlayTimer);
        autoPlayTimer = null;
    }
}

function startDualAutoPlay() {
    if (autoPlayTimer) {
        clearInterval(autoPlayTimer);
        autoPlayTimer = null;
        return;
    }
    autoPlayTimer = setInterval(dualNextStep, 300);
}

// ==================== 标签页2: 算法对比实验室 ====================
function renderCRPLaboratory(container) {
    var html = '' +
        '<div style="display: grid; grid-template-columns: 280px 1fr; gap: 15px;">' +
            '<div>' +
                '<div class="port-card">' +
                    '<div class="card-header"><span class="card-title">💡 为什么要优化？</span></div>' +
                    '<div style="padding: 15px;">' +
                        '<div style="color: #ff6b6b; font-weight: 600; font-size: 13px; margin-bottom: 10px;">❌ 传统翻箱的痛点</div>' +
                        '<div style="color: #a0c4e8; font-size: 11px; line-height: 1.7;">' +
                            '• 作业员只看当前，把阻挡箱往"最矮的栈"乱放<br>' +
                            '• 经常把早要提的箱子压在下面<br>' +
                            '• 导致恶性循环，越到后面翻箱越多<br>' +
                            '• 千万级大港年浪费超2亿元</div>' +
                        '<div style="color: #00ff88; font-weight: 600; font-size: 13px; margin: 15px 0 10px;">✅ A*智能优化的价值</div>' +
                        '<div style="color: #a0c4e8; font-size: 11px; line-height: 1.7;">' +
                            '• 提前看到未来N步，"这个箱子放哪未来翻箱最少"<br>' +
                            '• 计算Badness值：这个位置会压住多少个更早提的箱<br>' +
                            '• 提取顺序相近的箱子尽量放在一起<br>' +
                            '• 翻箱率降低40~60%，直接节省上亿成本</div>' +
                    '</div>' +
                '</div>' +
                '<div class="port-card" style="margin-top: 15px;">' +
                    '<div class="card-header"><span class="card-title">📊 实时对比</span></div>' +
                    '<div style="padding: 15px;">' +
                        '<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px;">' +
                            '<div style="padding: 10px; background: rgba(255,107,107,0.1); border-radius: 6px; text-align: center;">' +
                                '<div style="color: #7a9aba; font-size: 9px;">传统翻箱</div>' +
                                '<div id="greedy-reloc" style="color: #ff6b6b; font-size: 20px; font-weight: 700;">0次</div>' +
                            '</div>' +
                            '<div style="padding: 10px; background: rgba(0,255,136,0.1); border-radius: 6px; text-align: center;">' +
                                '<div style="color: #7a9aba; font-size: 9px;">A*优化后</div>' +
                                '<div id="astar-reloc" style="color: #00ff88; font-size: 20px; font-weight: 700;">0次</div>' +
                            '</div>' +
                        '</div>' +
                        '<div style="padding: 12px; background: linear-gradient(135deg, rgba(0,255,136,0.15), rgba(255,193,7,0.1)); border-radius: 6px; text-align: center;">' +
                            '<div style="color: #7a9aba; font-size: 9px;">A*节省翻箱</div>' +
                            '<div id="saving-count" style="color: #ffc107; font-size: 24px; font-weight: 700;">0次 (0%)</div>' +
                        '</div>' +
                    '</div>' +
                '</div>' +
            '</div>' +
            '<div>' +
                '<div class="port-card">' +
                    '<div class="card-header">' +
                        '<span class="card-title">⚔️ 双算法实时对比</span>' +
                        '<button class="port-btn" onclick="initDualSimulator()" style="margin-right: 8px;">🔄 重置</button>' +
                        '<button class="port-btn" onclick="startDualAutoPlay()" style="margin-right: 8px;">⏯️ 自动播放</button>' +
