                    '</div>' +
                    '<div style="padding: 8px; border-bottom: 2px solid rgba(255,107,107,0.3);">' +
                        '<div style="color: #ff6b6b; font-weight: 700; font-size: 13px; margin-bottom: 5px;">❌ 传统贪心策略 (哪个矮放哪)</div>' +
