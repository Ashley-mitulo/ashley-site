                        '<div id="greedy-yard" style="min-height: 220px;"></div>' +
                    '</div>' +
                    '<div style="padding: 8px;">' +
                        '<div style="color: #00ff88; font-weight: 700; font-size: 13px; margin-bottom: 5px;">✅ A*智能策略 (Badness值最优)</div>' +
                        '<div style="color: #7a9aba; font-size: 10px; margin-bottom: 5px;">进度: <span id="astar-progress">0/80</span></div>' +
                        '<div id="astar-yard" style="min-height: 220px;"></div>' +
                    '</div>' +
                '</div>' +
