                            <th style="padding: 8px 5px;">操作内容</th>
                            <th style="width: 70px; padding: 8px 5px;">类型</th>
                            <th style="padding: 8px 5px;">A*算法决策逻辑</th>
                            <th style="width: 70px; padding: 8px 5px;">累计翻箱</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td style="text-align: center; font-weight: 600;">1</td><td>将箱6从栈2顶移至栈4(空)</td><td><span class="status-badge stopped">翻箱</span></td><td style="font-size: 11px; color: #b388ff;">优先用空栈缓存，避免后续与其他箱冲突</td><td style="text-align: center; font-weight: 600; color: #ff6b6b;">1</td></tr>
                        <tr><td style="text-align: center; font-weight: 600;">2</td><td>将箱11从栈2顶移至栈3</td><td><span class="status-badge stopped">翻箱</span></td><td style="font-size: 11px; color: #b388ff;">同港就近堆放，栈3有空位，减少后续翻箱</td><td style="text-align: center; font-weight: 600; color: #ff6b6b;">2</td></tr>
                        <tr><td style="text-align: center; font-weight: 600;">3</td><td>将箱4从栈2顶移至栈1</td><td><span class="status-badge stopped">翻箱</span></td><td style="font-size: 11px; color: #b388ff;">栈1顶层箱优先级高，后续提4只需再翻1次</td><td style="text-align: center; font-weight: 600; color: #ff6b6b;">3</td></tr>
                        <tr style="background: rgba(0,255,136,0.08);"><td style="text-align: center; font-weight: 600; color: #00ff88;">4 ✅</td><td style="color: #00ff88; font-weight: 600;">提取目标箱1 从栈2底层</td><td><span class="status-badge working">提取</span></td><td style="font-size: 11px; color: #00ff88;">仅3次翻箱即提取第1个目标！FCFS需要5次</td><td style="text-align: center; font-weight: 600; color: #00ff88;">3</td></tr>
                        <tr><td style="text-align: center; font-weight: 600;">5</td><td>将箱15从栈1顶移至栈4</td><td><span class="status-badge stopped">翻箱</span></td><td style="font-size: 11px; color: #b388ff;">A*预判：箱2是下一个目标，上面只有箱15挡着</td><td style="text-align: center; font-weight: 600; color: #ff6b6b;">4</td></tr>
                        <tr style="background: rgba(0,255,136,0.08);"><td style="text-align: center; font-weight: 600; color: #00ff88;">6 ✅</td><td style="color: #00ff88; font-weight: 600;">提取目标箱2 从栈1底层</td><td><span class="status-badge working">提取</span></td><td style="font-size: 11px; color: #00ff88;">提前预判，只多翻1次就拿到箱2</td><td style="text-align: center; font-weight: 600; color: #00ff88;">4</td></tr>
                        <tr><td style="text-align: center; font-weight: 600;">7</td><td>将箱8从栈1顶移至栈2(空)</td><td><span class="status-badge stopped">翻箱</span></td><td style="font-size: 11px; color: #b388ff;">栈2已空，空栈优先堆放，减少碰撞概率</td><td style="text-align: center; font-weight: 600; color: #ff6b6b;">5</td></tr>
                        <tr style="background: rgba(0,255,136,0.08);"><td style="text-align: center; font-weight: 600; color: #00ff88;">8 ✅</td><td style="color: #00ff88; font-weight: 600;">提取目标箱3 从栈5顶层</td><td><span class="status-badge working">提取</span></td><td style="font-size: 11px; color: #00ff88;">箱3刚好在顶层，零翻箱直接提取！</td><td style="text-align: center; font-weight: 600; color: #00ff88;">5</td></tr>
                        <tr style="background: rgba(0,255,136,0.08);"><td style="text-align: center; font-weight: 600; color: #00ff88;">9 ✅</td><td style="color: #00ff88; font-weight: 600;">提取目标箱4 从栈1顶层</td><td><span class="status-badge working">提取</span></td><td style="font-size: 11px; color: #00ff88;">第3步翻出来的箱子！A*远见的体现！</td><td style="text-align: center; font-weight: 600; color: #00ff88;">5</td></tr>
                        <tr><td style="text-align: center; font-weight: 600;">10</td><td>将箱18从栈3顶移至栈2</td><td><span class="status-badge stopped">翻箱</span></td><td style="font-size: 11px; color: #b388ff;">为提取箱5腾空间，继续保持栈4备用</td><td style="text-align: center; font-weight: 600; color: #ff6b6b;">6</td></tr>
                        <tr style="background: rgba(0,255,136,0.08);"><td style="text-align: center; font-weight: 600; color: #00ff88;">11 ✅</td><td style="color: #00ff88; font-weight: 600;">提取目标箱5 从栈3</td><td><span class="status-badge working">提取</span></td><td style="font-size: 11px; color: #00ff88;">仅1次翻箱，高效提取箱5</td><td style="text-align: center; font-weight: 600; color: #00ff88;">6</td></tr>
                        <tr style="background: rgba(0,255,136,0.08);"><td style="text-align: center; font-weight: 600; color: #00ff88;">12 ✅</td><td style="color: #00ff88; font-weight: 600;">提取目标箱6 从栈4顶层</td><td><span class="status-badge working">提取</span></td><td style="font-size: 11px; color: #00ff88;">第1步翻到栈4缓存的，现在直接提！节省3次翻箱！</td><td style="text-align: center; font-weight: 600; color: #00ff88;">6</td></tr>
                    </tbody>
                </table>
                <div style="margin-top: 20px; padding: 15px; background: rgba(0,255,136,0.05); border-radius: 8px; border-left: 4px solid #00ff88;">
                    <div style="color: #00ff88; font-weight: 600; font-size: 14px;">🎯 关键结论</div>
                    <div style="color: #a0c4e8; font-size: 12px; margin-top: 8px; line-height: 1.8;">
                        前12步就提取了6个目标箱，仅翻箱6次（平均每箱翻1次），而FCFS算法需要翻14次！<br/>
                        <strong style="color: #00ff88;">核心差异：</strong>A*算法第1步就把箱6放到栈4缓存，FCFS会把箱6随便乱放导致后面还要再翻3次才能拿到。<br/>
                        这就是启发式算法"预见未来"的价值！
                    </div>
                </div>
            </div>
        </div>
    `;
}

function renderYardVisual() {
    // 经典CRP测试用例：6个栈，每个栈的箱子（从底层到顶层）
    // 数字越小 = 提取优先级越高
    const yard = [
        [15, 8, 2],     // 栈1：底层15 → 8 → 顶层2
        [6, 11, 4, 1],  // 栈2：目标箱1在最底层！上面压了3个阻挡箱
        [12, 5, 18],    // 栈3
        [],              // 栈4：空栈（缓冲区）
        [20, 7, 16, 3], // 栈5：箱3在顶层（好运）
        [9, 19, 10, 13, 14] // 栈6
    ];
    
    let html = '';
    for (let s = 0; s < 6; s++) {
        const stack = yard[s];
        html += '<div style="display: flex; flex-direction: column; align-items: center; gap: 5px;">'
             + '<div style="color: #7a9aba; font-size: 12px; font-weight: 600; margin-bottom: 8px;">栈' + (s+1) + (s === 3 ? '(缓冲)' : '') + '</div>';
        
        // 从顶层到底层渲染（视觉上符合堆放）
        for (let t = stack.length - 1; t >= 0; t--) {
            const box = stack[t];
            let bgColor = '#4a5568'; // 后续提取
            if (box === 1) bgColor = '#00ff88'; // 目标箱
            else if (s === 1 && t < 3) bgColor = '#ff6b6b'; // 栈2的阻挡箱（箱6,11,4）
            
            html += '<div style="width: 50px; height: 42px; background: ' + bgColor + '; border-radius: 5px; display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 700; font-size: 15px; box-shadow: 0 2px 8px rgba(0,0,0,0.3);">' + box + '</div>';
        }
        // 空位填充对齐
        for (let t = stack.length; t < 5; t++) {
            html += '<div style="width: 50px; height: 42px; border: 1px dashed rgba(122,154,186,0.25); border-radius: 5px;"></div>';
        }
        html += '<div style="width: 60px; height: 6px; background: #3a5a7a; border-radius: 3px; margin-top: 5px;"></div></div>';
    }
    return html;
}

// ==================== 算法3: 集卡路径优化 ====================
function renderRoutingAlgo(container) {
    container.innerHTML = `
        <div class="port-card">
            <div class="card-header">
                <span class="card-title">🚛 集卡路径优化 - A*路径规划 + 拍卖算法调度</span>
            </div>
            <div style="padding: 30px;">
                <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; margin-bottom: 30px;">
                    <div style="padding: 20px; background: rgba(0,255,136,0.08); border-radius: 10px; text-align: center;">
                        <div style="color: #7a9aba; font-size: 12px;">平均空驶率</div>
                        <div style="color: #00ff88; font-size: 28px; font-weight: 700;">18.2%</div>
                        <div style="color: #00ff88; font-size: 12px;">↓ 23%</div>
                    </div>
                    <div style="padding: 20px; background: rgba(0,212,255,0.08); border-radius: 10px; text-align: center;">
                        <div style="color: #7a9aba; font-size: 12px;">日均作业量</div>
                        <div style="color: #00d4ff; font-size: 28px; font-weight: 700;">2100TEU</div>
                        <div style="color: #00d4ff; font-size: 12px;">↑ 15%</div>
                    </div>
                    <div style="padding: 20px; background: rgba(255,193,7,0.08); border-radius: 10px; text-align: center;">
                        <div style="color: #7a9aba; font-size: 12px;">平均行驶距离</div>
                        <div style="color: #ffc107; font-size: 28px; font-weight: 700;">2.3km</div>
                        <div style="color: #ffc107; font-size: 12px;">↓ 18%</div>
                    </div>
                    <div style="padding: 20px; background: rgba(179,136,255,0.08); border-radius: 10px; text-align: center;">
                        <div style="color: #7a9aba; font-size: 12px;">双层优化架构</div>
                        <div style="color: #b388ff; font-size: 20px; font-weight: 700;">A* + 拍卖</div>
                    </div>
                </div>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 25px;">
                    <div style="padding: 20px; background: rgba(0,0,0,0.1); border-radius: 10px;">
                        <h4 style="color: #00d4ff; margin-bottom: 15px; font-size: 15px;">🗺️ 下层：A*路网路径规划</h4>
                        <div style="color: #a0c4e8; font-size: 12px; line-height: 2.2;">
                            <p><strong>评价函数：f(n) = g(n) + h(n)</strong></p>
                            <p>• g(n)：从起点到当前节点的真实行驶距离</p>
                            <p>• h(n)：欧氏距离到终点（可采纳下界）</p>
                            <p>• 保证找到最短路径的同时，比Dijkstra少探索65%节点</p>
                            <div style
="margin-top: 10px; padding: 10px; background: rgba(0,212,255,0.08); border-radius: 6px;">
                                <div style="color: #00d4ff; font-size: 11px; font-weight: 600;">典型场景</div>
                                <div style="color: #a0c4e8; font-size: 11px;">B03泊位 → 堆场A区：A*规划最优路径1.8km，比人工选择节省0.5km/趟</div>
                            </div>
                        </div>
                    </div>
                    <div style="padding: 20px; background: rgba(0,0,0,0.1); border-radius: 10px;">
                        <h4 style="color: #b388ff; margin-bottom: 15px; font-size: 15px;">💰 上层：拍卖算法任务分配</h4>
                        <div style="color: #a0c4e8; font-size: 12px; line-height: 2.2;">
                            <p><strong>每台集卡独立计算投标价：</strong></p>
                            <p>bid = 距离成本 × 2.5 + 等待时间成本 × 0.8 + 优先级惩罚</p>
                            <p>• 最低出价者获得任务 → 全局成本最优</p>
                            <p>• 分布式计算，无单点瓶颈，毫秒级完成分配</p>
                            <div style="margin-top: 10px; padding: 10px; background: rgba(179,136,255,0.08); border-radius: 6px;">
                                <div style="color: #b388ff; font-size: 11px; font-weight: 600;">典型案例</div>
                                <div style="color: #a0c4e8; font-size: 11px;">4台集卡同时投标4个任务，全局总成本降低18%，空驶率从41%降至18%</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    `;
}

