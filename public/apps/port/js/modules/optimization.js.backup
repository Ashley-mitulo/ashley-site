// ============================================================
// 🧠 港口智能算法优化中心
// ============================================================

let currentAlgoTab = 'berth';
let crpStep = 0;

// ==================== 主入口函数 ====================
function renderOptimization(container) {
    container.innerHTML = `
        <div class="page-title">🧠 港口智能算法优化中心</div>
        
        <div class="tab-container">
            <div class="tab-item active" onclick="switchAlgoTab('berth')">🚢 泊位调度优化</div>
            <div class="tab-item" onclick="switchAlgoTab('relocation')">📦 翻箱率优化(核心)</div>
            <div class="tab-item" onclick="switchAlgoTab('routing')">🚛 集卡路径优化</div>
        </div>
        
        <div id="algo-tab-content"></div>
    `;
    switchAlgoTab('berth');
}

function switchAlgoTab(tab) {
    currentAlgoTab = tab;
    document.querySelectorAll('.tab-container .tab-item').forEach((item, idx) => {
        item.classList.remove('active');
        const tabs = ['berth', 'relocation', 'routing'];
        if (tabs[idx] === tab) item.classList.add('active');
    });
    
    const content = document.getElementById('algo-tab-content');
    switch(tab) {
        case 'berth': renderBerthAlgo(content); break;
        case 'relocation': renderRelocationAlgo(content); break;
        case 'routing': renderRoutingAlgo(content); break;
    }
}

// ==================== 算法1: 泊位调度优化 ====================
function renderBerthAlgo(container) {
    container.innerHTML = `
        <div class="port-card">
            <div class="card-header">
                <span class="card-title">🚢 泊位调度优化 - 遗传算法</span>
                <button class="port-btn port-btn-primary" onclick="runOptimization()">🚀 运行优化</button>
            </div>
            <div style="padding: 30px;">
                <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; margin-bottom: 30px;">
                    <div style="padding: 20px; background: rgba(0,255,136,0.08); border-radius: 10px; text-align: center;">
                        <div style="color: #7a9aba; font-size: 12px;">平均等待时间</div>
                        <div style="color: #00ff88; font-size: 28px; font-weight: 700;">2.8 小时</div>
                        <div style="color: #00ff88; font-size: 12px;">↓ 35%</div>
                    </div>
                    <div style="padding: 20px; background: rgba(0,212,255,0.08); border-radius: 10px; text-align: center;">
                        <div style="color: #7a9aba; font-size: 12px;">泊位利用率</div>
                        <div style="color: #00d4ff; font-size: 28px; font-weight: 700;">85%</div>
                        <div style="color: #00d4ff; font-size: 12px;">↑ 12%</div>
                    </div>
                    <div style="padding: 20px; background: rgba(255,193,7,0.08); border-radius: 10px; text-align: center;">
                        <div style="color: #7a9aba; font-size: 12px;">最大延误</div>
                        <div style="color: #ffc107; font-size: 28px; font-weight: 700;">4.5 小时</div>
                        <div style="color: #ffc107; font-size: 12px;">↓ 40%</div>
                    </div>
                    <div style="padding: 20px; background: rgba(179,136,255,0.08); border-radius: 10px; text-align: center;">
                        <div style="color: #7a9aba; font-size: 12px;">算法类型</div>
                        <div style="color: #b388ff; font-size: 24px; font-weight: 700;">遗传算法</div>
                        <div style="color: #b388ff; font-size: 12px;">种群: 100</div>
                    </div>
                </div>
            </div>
        </div>
    `;
}

function runOptimization() {
    showToast('遗传算法运行中... 种群进化中...', 'info');
    setTimeout(() => showToast('优化完成！已生成最优泊位分配方案', 'success'), 1500);
}

// ==================== 算法2: 翻箱率优化 - 核心CRP算法 ====================
function renderRelocationAlgo(container) {
    crpStep = 0;
    
    container.innerHTML = `
        <div class="port-card">
            <div class="card-header">
                <span class="card-title">🎯 什么是真正的港口翻箱问题？(CRP)</span>
            </div>
            <div style="padding: 25px;">
                <div style="background: linear-gradient(135deg, rgba(255,193,7,0.1), rgba(255,87,34,0.05)); border-radius: 10px; padding: 20px; border-left: 4px solid #ffc107;">
                    <h4 style="color: #ffc107; margin-bottom: 15px;">📖 核心问题定义 (集装箱预翻箱问题)</h4>
                    <div style="color: #a0c4e8; font-size: 13px; line-height: 2;">
                        <p><strong style="color: #fff;">已知条件：</strong></p>
                        <ul style="margin: 5px 0 15px 25px;">
                            <li>堆场有 <strong style="color: #00d4ff;">6个栈位</strong>，每栈最多堆5层</li>
                            <li>箱子堆放是<strong style="color: #ff6b6b;">乱序的</strong>（物理堆放限制导致）</li>
                            <li>提箱有<strong style="color: #00ff88;">固定优先级序列</strong>：必须按1→2→3→…顺序提</li>
                        </ul>
                        <p><strong style="color: #fff;">目标：全局总翻箱次数 MINIMIZE</strong></p>
                        <p style="color: #ffc107; margin-top: 8px;">💡 难点：现在翻哪个箱、放哪个栈，会影响未来几十步的翻箱成本！需要全局最优决策，不是局部贪心。</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="port-card" style="margin-top: 15px;">
            <div class="card-header">
                <span class="card-title">📦 堆场可视化 (6栈 × 5层 = 20箱)</span>
                <span style="color: #7a9aba; font-size: 12px;">提箱顺序：1 → 2 → 3 → ... → 20（数字越小优先级越高）</span>
            </div>
            <div style="padding: 25px;">
                <div style="display: flex; align-items: flex-end; justify-content: center; gap: 15px; min-height: 300px;" id="yard-display">
                    ${renderYardVisual()}
                </div>
                <div style="display: flex; gap: 25px; justify-content: center; margin-top: 20px; flex-wrap: wrap;">
                    <span style="display: flex; align-items: center; gap: 8px; font-size: 12px; color: #a0c4e8;">
                        <span style="width: 28px; height: 28px; background: #00ff88; border-radius: 4px; display: flex; align-items: center; justify-content: center; color: #000; font-weight: 700;">1</span>目标箱(下一个提取)
                    </span>
                    <span style="display: flex; align-items: center; gap: 8px; font-size: 12px; color: #a0c4e8;">
                        <span style="width: 28px; height: 28px; background: #ff6b6b; border-radius: 4px; display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 700;">6</span>阻挡箱(必须翻)
                    </span>
                    <span style="display: flex; align-items: center; gap: 8px; font-size: 12px; color: #a0c4e8;">
                        <span style="width: 28px; height: 28px; background: #4a5568; border-radius: 4px; display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 700;">20</span>后续提取
                    </span>
                </div>
            </div>
        </div>

        <div class="port-card" style="margin-top: 15px;">
            <div class="card-header">
                <span class="card-title">📊 算法优化效果对比</span>
            </div>
            <div style="padding: 25px;">
                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 25px;">
                    <div style="padding: 20px; background: rgba(255,107,107,0.1); border-radius: 10px; text-align: center;">
                        <div style="color: #7a9aba; font-size: 12px;">❌ FCFS先来先服务</div>
